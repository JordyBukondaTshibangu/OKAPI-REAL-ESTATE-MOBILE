{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-dev.okapi-real-estate.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-qa.okapi-real-estate.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.okapi-real-estate.com"
      }
    },
    "testflight": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-qa.okapi-real-estate.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jordytshibangu1@gmail.com",
        "appleTeamId": "YBHH4R48C5"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "production"
      }
    }
  }
}
